# Environment variables for Docker Compose
# Copy this file to .env and add your actual Paystack keys

# Backend - Paystack Secret Key (starts with sk_test_ for test mode)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Frontend - Paystack Public Key (starts with pk_test_ for test mode)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
